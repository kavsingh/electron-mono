	},
	"type": "module",
	"scripts": {
		"dev": "nx dev app",
		"build": "nx build app",
		"build:mac": "nx build:mac app",
		"build:linux": "nx build:linux app",
		"build:win:x64": "nx build:win:x64 app",
		"build:win:arm64": "nx build:win:arm64 app",
		"test": "nx run-many -t test",
