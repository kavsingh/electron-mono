{
	"name": "electron-typed-ipc",
	"version": "1.0.0-dev.0",
	"description": "typed electron ipc",
	"keywords": [],
	"author": "<author>",
	"license": "MIT",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"files": [
		"./dist"
	],
	"exports": {
		".": {
			"import": {
				"types": "./dist/common.d.ts",
				"default": "./dist/common.js"
			},
			"require": {
				"types": "./dist/common.d.cts",
				"default": "./dist/common.cjs"
			}
		},
		"./main": {
			"import": {
				"types": "./dist/main.d.ts",
				"default": "./dist/main.js"
			},
			"require": {
				"types": "./dist/main.d.cts",
				"default": "./dist/main.cjs"
			}
		},
		"./preload": {
			"import": {
				"types": "./dist/preload.d.ts",
				"default": "./dist/preload.js"
			},
			"require": {
				"types": "./dist/preload.d.cts",
				"default": "./dist/preload.cjs"
			}
		},
		"./renderer": {
			"import": {
				"types": "./dist/renderer.d.ts",
				"default": "./dist/renderer.js"
			},
			"require": {
				"types": "./dist/renderer.d.cts",
				"default": "./dist/renderer.cjs"
			}
		},
		"./test/renderer": {
			"import": {
				"types": "./dist/test-renderer.d.ts",
				"default": "./dist/test-renderer.js"
			},
			"require": {
				"types": "./dist/test-renderer.d.cts",
				"default": "./dist/test-renderer.cjs"
			}
		}
	},
	"scripts": {
		"lint": "tsc && eslint .",
		"tdd": "vitest --typecheck --reporter=verbose",
		"test": "vitest run --typecheck --coverage",
		"build": "tsup"
	},
	"devDependencies": {
		"@vitest/coverage-v8": "3.1.1",
		"electron": "35.1.2",
		"eslint-plugin-vitest": "0.5.4",
		"superjson": "2.2.2",
		"tsup": "8.4.0",
		"vitest": "3.1.1",
		"zod": "3.24.2"
	},
	"peerDependencies": {
		"electron": ">=35",
		"superjson": ">=2"
	}
}
