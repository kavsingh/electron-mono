{
	"$schema": "https://json.schemastore.org/tsconfig",
	"include": [
		"./src/common",
		"./src/renderer",
		"./src/vitest.renderer.setup.ts",
		"./src/main/trpc"
	],
	"extends": ["../../tsconfig.base.json"],
	"compilerOptions": {
		"composite": true,
		"emitDeclarationOnly": true,
		"jsx": "preserve",
		"jsxImportSource": "solid-js",
		"lib": ["es2023", "dom", "dom.asynciterable"],
		"module": "esnext",
		"moduleResolution": "bundler",
		"paths": {
			"~/common/*": ["./src/common/*"],
			"~/renderer/*": ["./src/renderer/*"],
			// needed for trpc type resolution
			"~/main/*": ["./src/main/*"]
		},
		"types": ["vite/client"]
	}
}
