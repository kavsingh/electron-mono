{
	"name": "app",
	"version": "1.0.0-dev.0",
	"description": "an electron app",
	"keywords": [],
	"license": "MIT",
	"author": "<author>",
	"type": "module",
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"start": "electron-vite preview",
		"lint": "oxlint --type-aware --type-check --max-warnings=0 && oxfmt --check",
		"tdd": "vitest --reporter=verbose",
		"test": "vitest run",
		"test:ci": "vitest run --silent --coverage --reporter=dot",
		"test:e2e": "pnpm run build && playwright test",
		"build:mac": "pnpm run build && electron-builder --mac --config electron-builder.config.ts",
		"build:linux": "pnpm run build && electron-builder --linux --config electron-builder.config.ts",
		"build:win:x64": "pnpm run build && electron-builder --win --x64 --config electron-builder.config.ts",
		"build:win:arm64": "pnpm run build && electron-builder --win --arm64 --config electron-builder.config.ts",
		"gen:electron-schema": "node ./scripts/gen-electron-zod.ts"
	},
	"dependencies": {
		"@trpc/server": "11.16.0",
		"electron-log": "5.4.3",
		"superjson": "2.2.6",
		"systeminformation": "5.31.5",
		"trpc-electron": "0.1.2",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@electron/fuses": "2.1.1",
		"@electron/notarize": "3.1.1",
		"@playwright/test": "1.59.1",
		"@solidjs/testing-library": "0.8.10",
		"@tailwindcss/vite": "4.2.2",
		"@tanstack/devtools-vite": "0.6.0",
		"@tanstack/eslint-plugin-router": "1.161.6",
		"@tanstack/router-cli": "1.166.25",
		"@tanstack/router-plugin": "1.167.12",
		"@tanstack/solid-devtools": "0.8.2",
		"@tanstack/solid-query": "5.97.0",
		"@tanstack/solid-query-devtools": "5.97.0",
		"@tanstack/solid-router": "1.168.9",
		"@tanstack/solid-router-devtools": "1.166.11",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/user-event": "14.6.1",
		"@trpc/client": "11.16.0",
		"@vitest/coverage-v8": "4.1.4",
		"electron": "41.2.0",
		"electron-builder": "26.8.1",
		"electron-vite": "5.0.0",
		"eslint-plugin-better-tailwindcss": "4.4.0",
		"eslint-plugin-jest-dom": "5.5.0",
		"eslint-plugin-playwright": "2.10.1",
		"eslint-plugin-solid": "0.14.5",
		"eslint-plugin-testing-library": "7.16.2",
		"jsdom": "29.0.2",
		"memfs": "4.57.1",
		"solid-js": "1.9.12",
		"tailwind-merge": "3.5.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.2.2",
		"ts-to-zod": "5.1.0",
		"tw-animate-css": "1.4.0",
		"vite": "7.3.1",
		"vite-plugin-solid": "2.11.12",
		"vite-tsconfig-paths": "6.1.1",
		"vitest": "4.1.4",
		"vitest-canvas-mock": "1.1.4"
	},
	"engines": {
		"node": ">=24"
	},
	"productName": "App"
}
