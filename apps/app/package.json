{
	"name": "app",
	"version": "1.0.0-dev.0",
	"description": "an electron app",
	"keywords": [],
	"license": "MIT",
	"author": "<author>",
	"type": "module",
	"main": "./out/main/index.cjs",
	"scripts": {
		"postinstall": "install-electron && install-app-deps",
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"start": "electron-vite preview",
		"lint": "tsr generate && oxlint && oxfmt --check",
		"tdd": "vitest --reporter=verbose",
		"test": "vitest run",
		"test:ci": "vitest run --silent --coverage --reporter=dot",
		"test:e2e": "pnpm run build && playwright test",
		"build:mac": "pnpm run build && electron-builder --mac --config electron-builder.config.ts",
		"build:linux": "pnpm run build && electron-builder --linux --config electron-builder.config.ts",
		"build:win:x64": "pnpm run build && electron-builder --win --x64 --config electron-builder.config.ts",
		"build:win:arm64": "pnpm run build && electron-builder --win --arm64 --config electron-builder.config.ts",
		"gen:electron-schema": "node ./scripts/gen-electron-zod.ts"
	},
	"dependencies": {
		"@trpc/server": "11.17.0",
		"electron-log": "5.4.4",
		"superjson": "2.2.6",
		"systeminformation": "5.31.7",
		"trpc-electron": "0.1.2",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@electron/fuses": "2.1.2",
		"@electron/notarize": "3.1.1",
		"@playwright/test": "1.60.0",
		"@solidjs/testing-library": "0.8.10",
		"@tailwindcss/vite": "4.3.0",
		"@tanstack/devtools-vite": "0.7.0",
		"@tanstack/eslint-plugin-router": "1.162.0",
		"@tanstack/router-cli": "1.167.17",
		"@tanstack/router-plugin": "1.168.18",
		"@tanstack/solid-devtools": "0.8.5",
		"@tanstack/solid-query": "5.101.0",
		"@tanstack/solid-query-devtools": "5.101.0",
		"@tanstack/solid-router": "1.170.15",
		"@tanstack/solid-router-devtools": "1.167.0",
		"@testing-library/dom": "10.4.1",
		"@testing-library/jest-dom": "6.9.1",
		"@testing-library/user-event": "14.6.1",
		"@trpc/client": "11.17.0",
		"@vitest/coverage-v8": "4.1.8",
		"electron": "42.4.0",
		"electron-builder": "26.15.3",
		"electron-vite": "6.0.0-beta.1",
		"eslint-plugin-better-tailwindcss": "4.5.0",
		"eslint-plugin-jest-dom": "5.5.0",
		"eslint-plugin-playwright": "2.10.4",
		"eslint-plugin-solid": "0.14.5",
		"eslint-plugin-testing-library": "7.16.2",
		"jsdom": "29.1.1",
		"memfs": "4.57.6",
		"solid-js": "1.9.13",
		"tailwind-merge": "3.6.0",
		"tailwind-variants": "3.2.2",
		"tailwindcss": "4.3.0",
		"terser": "5.48.0",
		"ts-to-zod": "5.1.0",
		"tw-animate-css": "1.4.0",
		"vite": "8.0.16",
		"vite-plugin-bundle-obfuscator": "1.12.0",
		"vite-plugin-solid": "2.11.12",
		"vitest": "4.1.8",
		"vitest-canvas-mock": "1.1.4"
	},
	"engines": {
		"node": ">=24"
	},
	"productName": "App"
}
