{
	"name": "app",
	"version": "1.0.0-dev.0",
	"description": "an electron app",
	"type": "module",
	"engines": {
		"node": ">=22"
	},
	"main": "./out/main/index.js",
	"scripts": {
		"dev": "electron-vite dev",
		"build": "electron-vite build",
		"start": "electron-vite preview",
		"lint": "eslint --flag unstable_ts_config .",
		"typecheck": "tsc",
		"codecheck": "pnpm run test && pnpm typecheck && pnpm lint",
		"test": "run-p test:node test:renderer",
		"test:node": "vitest run -c vitest.node.config.ts",
		"test:renderer": "vitest run -c vitest.renderer.config.ts",
		"test:ci": "run-p test:ci:node test:ci:renderer",
		"test:ci:node": "vitest run -c vitest.node.config.ts --silent --coverage",
		"test:ci:renderer": "vitest run -c vitest.renderer.config.ts --silent --coverage",
		"testwatch": "run-p testwatch:**",
		"testwatch:node": "vitest -c vitest.node.config.ts",
		"testwatch:renderer": "vitest -c vitest.renderer.config.ts",
		"test:e2e": "cross-env E2E=true pnpm run build && playwright test",
		"build:win": "pnpm run build && electron-builder --win --config electron-builder.config.ts",
		"build:mac": "pnpm run build && electron-builder --mac --config electron-builder.config.ts",
		"build:linux": "pnpm run build && electron-builder --linux --config electron-builder.config.ts",
		"gen:electron-schema": "node --import=jiti/register ./scripts/gen-electron-zod.ts"
	},
	"keywords": [],
	"author": "<author>",
	"license": "MIT",
	"dependencies": {
		"@trpc/server": "10.45.2",
		"chalk": "5.3.0",
		"electron-log": "5.2.0",
		"electron-trpc": "0.6.1",
		"eventemitter3": "5.0.1",
		"superjson": "2.2.1",
		"systeminformation": "5.23.5",
		"zod": "3.23.8"
	},
	"devDependencies": {
		"@electron-mono/shared": "workspace:*",
		"@electron/notarize": "2.5.0",
		"@eslint/compat": "1.2.1",
		"@playwright/test": "1.48.1",
		"@tailwindcss/container-queries": "0.1.1",
		"@tanstack/react-query": "5.59.15",
		"@testing-library/dom": "10.4.0",
		"@testing-library/jest-dom": "6.6.2",
		"@testing-library/react": "16.0.1",
		"@testing-library/user-event": "14.5.2",
		"@trpc/client": "10.45.2",
		"@types/eslint-plugin-tailwindcss": "3.17.0",
		"@types/react": "18.3.11",
		"@types/react-dom": "18.3.1",
		"@vitejs/plugin-react": "4.3.3",
		"@vitest/coverage-v8": "2.1.3",
		"autoprefixer": "10.4.20",
		"babel-plugin-react-compiler": "19.0.0-beta-8a03594-20241020",
		"electron": "33.0.1",
		"electron-builder": "25.1.8",
		"electron-vite": "2.3.0",
		"eslint-plugin-jest-dom": "5.4.0",
		"eslint-plugin-playwright": "1.8.1",
		"eslint-plugin-react": "7.37.1",
		"eslint-plugin-react-compiler": "19.0.0-beta-8a03594-20241020",
		"eslint-plugin-react-hooks": "5.0.0",
		"eslint-plugin-tailwindcss": "3.17.5",
		"eslint-plugin-testing-library": "6.4.0",
		"eslint-plugin-vitest": "0.5.4",
		"jsdom": "25.0.1",
		"postcss": "8.4.47",
		"react": "19.0.0-rc-8b08e99e-20240713",
		"react-dom": "19.0.0-rc-8b08e99e-20240713",
		"react-router-dom": "6.27.0",
		"tailwind-variants": "0.2.1",
		"tailwindcss": "3.4.14",
		"ts-to-zod": "3.13.0",
		"vite": "5.4.9",
		"vite-tsconfig-paths": "5.0.1",
		"vitest": "2.1.3",
		"vitest-canvas-mock": "0.3.3"
	}
}
